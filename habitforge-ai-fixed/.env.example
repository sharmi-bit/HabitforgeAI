NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: "anthropic" | "openai" | "huggingface" | "custom"
AI_PROVIDER=anthropic

# API key for the chosen provider
AI_API_KEY=your_api_key_here

# Model name (optional — sensible defaults are set per provider)
AI_MODEL=claude-haiku-4-5-20251001

# For AI_PROVIDER=openai pointing to a non-OpenAI endpoint (Groq, Together, etc.)
# AI_MODEL_API_URL=https://api.groq.com/openai/v1
